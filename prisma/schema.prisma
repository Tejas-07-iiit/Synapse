datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  positions    Position[]
  trades       Trade[]
  wallet       Wallet?
  settings     UserSettings?
}

model TradeSignal {
  id               String   @id @default(uuid())
  symbol           String
  timeframe        String
  strategyId       String
  direction        String   // LONG, SHORT, HOLD
  confidence       Float
  entry            Float
  stopLoss         Float
  takeProfit       Float
  timestamp        DateTime
  reasoning        String[] // Array of reasoning strings
  createdAt        DateTime @default(now())
  
  userId           String?
  tradingMode      String?  // SCALPING, INTRADAY
  blocked          Boolean  @default(false)
  blockReason      String?
  activePositionId String?
  
  confidenceScore  Int?
  marketRegime     String?
  atr              Float?
  positionSizeUsdt Float?
  
  @@index([symbol, timeframe])
  @@index([strategyId])
  @@index([userId])
}

model SignalLog {
  id          String   @id @default(uuid())
  symbol      String
  timeframe   String
  strategyId  String
  direction   String
  confidence  Float
  reasoning   String[]
  indicators  Json     // Store raw indicators snapshot
  timestamp   DateTime
  createdAt   DateTime @default(now())
}

model StrategyExecution {
  id           String   @id @default(uuid())
  strategyId   String
  symbol       String
  timeframe    String
  timestamp    DateTime @default(now())
  durationMs   Int
  signalResult String   // LONG, SHORT, HOLD
  success      Boolean  @default(true)
}

model IndicatorSnapshot {
  id          String   @id @default(uuid())
  symbol      String
  timeframe   String
  timestamp   DateTime
  rsi         Float?
  ema12       Float?
  ema26       Float?
  ema20       Float?
  sma50       Float?
  macdLine    Float?
  signalLine  Float?
  macdHist    Float?
  bbUpper     Float?
  bbMiddle    Float?
  bbLower     Float?
  atr         Float?
  vwap        Float?
  volume      Float?
  createdAt   DateTime @default(now())

  @@index([symbol, timeframe, timestamp])
}

model MarketSnapshot {
  id          String   @id @default(uuid())
  symbol      String
  timeframe   String
  timestamp   DateTime
  open        Float
  high        Float
  low         Float
  close       Float
  volume      Float
  createdAt   DateTime @default(now())

  @@index([symbol, timeframe, timestamp])
}

model Position {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  symbol            String
  direction         String    // LONG, SHORT
  entryPrice        Float
  currentPrice      Float
  quantity          Float
  stopLoss          Float?
  takeProfit        Float?
  leverage          Int       @default(1)
  pnl               Float     @default(0.0)
  status            String    // OPEN, CLOSED
  openedAt          DateTime  @default(now())
  closedAt          DateTime?
  // Strategy intelligence fields
  strategyId        String?
  strategyName      String?
  strategyCategory  String?
  entryReason       String?
  confidenceAtEntry Float?
  marketRegime      String?
  indicatorSnapshot Json?
  auditPayload      Json?

  expiresAt         DateTime?
  exitReason        String?
  confidenceScore   Int?

  @@index([userId])
  @@index([symbol])
}

model Trade {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  symbol            String
  strategyName      String
  direction         String    // LONG, SHORT
  entryPrice        Float
  exitPrice         Float
  currentPrice      Float?
  stopLoss          Float?
  takeProfit        Float?
  quantity          Float     @default(0.0)
  leverage          Int       @default(1)
  pnl               Float
  roi               Float     // ROI %
  confidence        Float     // Confidence score used
  status            String    // OPEN, CLOSED, STOPPED, TP HIT
  openedAt          DateTime
  closedAt          DateTime  @default(now())
  executionType     String    // PAPER, LIVE
  
  // Audit metadata
  tradingMode       String?
  marketRegime      String?
  atrAtEntry        Float?
  entryReason       String?
  exitReason        String?
  strategyId        String?
  strategyCategory  String?
  confidenceAtEntry Float?
  indicatorSnapshot Json?
  auditPayload      Json?
  
  entryFee          Float     @default(0)
  exitFee           Float     @default(0)
  totalFees         Float     @default(0)
  grossPnl          Float     @default(0)
  netPnl            Float     @default(0)
  feeRate           Float     @default(0.001)

  expiresAt         DateTime?
  confidenceScore   Int?

  @@index([userId])
  @@index([symbol])
}

model Strategy {
  id          String   @id
  name        String
  description String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  signals     Signal[]
}

model Signal {
  id           String   @id @default(uuid())
  strategyId   String
  strategy     Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  symbol       String
  timeframe    String
  signalType   String   // LONG, SHORT, HOLD
  confidence   Float
  entry        Float
  stopLoss     Float
  takeProfit   Float
  reasoning    String[]
  indicators   Json     // Store indicator snapshot at time of signal
  timestamp    DateTime
  createdAt    DateTime @default(now())

  confidenceScore  Int?
  marketRegime     String?

  @@index([symbol, timeframe])
  @@index([strategyId])
}

model StrategyResult {
  id           String   @id @default(uuid())
  strategyId   String
  symbol       String
  timeframe    String
  timestamp    DateTime @default(now())
  durationMs   Int
  signalResult String   // LONG, SHORT, HOLD
  success      Boolean  @default(true)
}

model Wallet {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance          Float    @default(10000.0) // Available balance
  totalDeposited   Float    @default(10000.0)
  totalWithdrawn   Float    @default(0.0)
  realizedPnl      Float    @default(0.0)
  updatedAt        DateTime @updatedAt
}

model UserSettings {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  autoTrading      Boolean  @default(true)
  maxOpenTrades    Int      @default(3)
  prefSymbol       String   @default("BTCUSDT")
  riskPerTradePct  Float    @default(2.0)
  updatedAt        DateTime @updatedAt

  preferredTradingMode TradingMode @default(INTRADAY)
}

enum TradingMode {
  SCALPING
  INTRADAY
}

// MCX V2 Postgres models. Independent from crypto trading tables.
model McxInstrument {
  id             String   @id @default(uuid())
  symbol         String
  token          String
  exchange       String
  expiry         DateTime
  contractName   String
  instrumentType String
  lotSize        Float
  tickSize       Float
  raw            Json
  active         Boolean  @default(true)
  syncedAt       DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([symbol, exchange, expiry, contractName])
  @@unique([token, exchange])
  @@index([symbol, active, expiry])
}

model McxTick {
  id           String   @id @default(uuid())
  symbol       String
  token        String
  exchange     String
  expiry       DateTime
  contractName String
  price        Float
  volume       Float
  timestamp    DateTime
  raw          Json?
  createdAt    DateTime @default(now())

  @@index([symbol, timestamp])
  @@index([token, timestamp])
}

model McxCandle {
  id           String   @id @default(uuid())
  symbol       String
  token        String
  exchange     String
  expiry       DateTime
  contractName String
  interval     String
  open         Float
  high         Float
  low          Float
  close        Float
  volume       Float
  timestamp    DateTime
  isClosed     Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([symbol, interval, timestamp])
  @@index([symbol, interval, isClosed, timestamp])
}

model McxWallet {
  id                  String   @id @default(uuid())
  userId              String   @unique
  equity              Float
  availableBalance    Float
  blockedMargin       Float    @default(0)
  realizedPnL         Float    @default(0)
  unrealizedPnL       Float    @default(0)
  tradingHalted       Boolean  @default(false)
  haltReason          String?
  dayStartEquity      Float
  highWatermarkEquity Float
  riskConfigVersion   String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model McxPosition {
  id            String    @id @default(uuid())
  openKey       String?   @unique
  userId        String
  symbol        String
  token         String
  exchange      String
  expiry        DateTime
  contractName  String
  side          String
  status        String
  entryPrice    Float
  exitPrice     Float?
  currentPrice  Float
  stopLoss      Float
  takeProfit    Float
  trailingStop  Float?
  quantity      Float
  lots          Float
  pointValue    Float
  marginUsed    Float
  riskAmount    Float
  pnl           Float     @default(0)
  unrealizedPnL Float     @default(0)
  strategyId    String
  strategyName  String
  confidence    Float
  openedAt      DateTime  @default(now())
  closedAt      DateTime?
  exitReason    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, status])
  @@index([symbol, status])
}

model McxTrade {
  id             String   @id @default(uuid())
  tradeId        String   @unique
  userId         String
  positionId     String?
  symbol         String
  token          String
  exchange       String
  expiry         DateTime
  contractName   String
  side           String
  type           String
  lots           Float
  quantity       Float
  price          Float
  entryPrice     Float?
  exitPrice      Float?
  stopLoss       Float?
  takeProfit     Float?
  strategy       String
  aiConfidence   Float
  profit         Float    @default(0)
  status         String
  reason         String?
  idempotencyKey String   @unique
  createdAt      DateTime @default(now())

  @@index([userId, symbol, createdAt])
}

model McxEventLog {
  id        String   @id @default(uuid())
  type      String
  payload   Json
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

model McxExecutionLock {
  key       String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model McxStrategyState {
  id         String   @id @default(uuid())
  userId     String
  strategyId String
  symbol     String
  state      Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, strategyId, symbol])
}
