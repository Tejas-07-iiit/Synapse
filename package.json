  {
  "name": "synapse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"crypto,mcx,next\" -c \"cyan,magenta,green\" \"tsx src/server/daemon.ts\" \"tsx src/mcx/daemon.ts\" \"NODE_OPTIONS='--max-old-space-size=4096' next dev\"",
    "dev:turbo": "concurrently -n \"crypto,mcx,next\" -c \"cyan,magenta,green\" \"tsx src/server/daemon.ts\" \"tsx src/mcx/daemon.ts\" \"NODE_OPTIONS='--max-old-space-size=4096' next dev --turbopack\"",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start": "NODE_OPTIONS='--max-old-space-size=2048' next start",
    "lint": "eslint",
    "replay": "npx tsx src/replay/cli.ts",
    "test:mcx": "tsx src/mcx/tests/run-tests.ts",
    "mcx:daemon": "tsx src/mcx/daemon.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/node-cron": "^3.0.11",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.40.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.16.0",
    "next": "15.5.18",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "otplib": "^13.4.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "smartapi-javascript": "^1.0.27",
    "tailwindcss-animate": "^1.0.7",
    "ws": "^8.21.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
